generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  RUT
  DNI
}

enum PetSpecies {
  PERRO
  GATO
}

enum PetSex {
  MACHO
  HEMBRA
}

enum MedicalRecordType {
  VACUNA
  CONSULTA
  ALERGIA
  DIAGNOSTICO
  TRATAMIENTO
  PESO
  NOTA
}

enum EventType {
  VACUNA
  CONTROL
  RECORDATORIO
  MEDICAMENTO
}

enum EventStatus {
  PENDIENTE
  COMPLETADO
  ATENCION
  CANCELADO
}

enum NotificationType {
  VACUNA
  CONTROL
  RECORDATORIO
  MEDICAMENTO
  SISTEMA
}

enum NotificationPriority {
  HIGH
  MEDIUM
  LOW
}

enum ReminderChannel {
  PUSH
  EMAIL
  IN_APP
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model User {
  id                  String          @id
  name                String
  email               String          @unique
  phone               String          @default("")
  country             String          @default("")
  city                String          @default("")
  documentType        DocumentType    @default(RUT)
  documentNumber      String          @default("")
  avatar              String
  passwordHash        String
  onboardingCompleted Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  sessions            Session[]
  pets                Pet[]
  medicalRecords      MedicalRecord[] @relation("MedicalRecordCreatedBy")
  events              Event[]         @relation("EventCreatedBy")
  notifications       Notification[]
}

model Session {
  id        String   @id
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Pet {
  id              String          @id
  userId          String
  name            String
  species         PetSpecies
  breed           String
  sex             PetSex
  birthDate       DateTime?
  weightCurrent   Float?
  color           String
  avatar          String
  isNeutered      Boolean         @default(false)
  microchipNumber String?
  notes           String          @default("")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalRecords  MedicalRecord[]
  events          Event[]
  notifications   Notification[]

  @@index([userId])
}

model MedicalRecord {
  id              String            @id
  petId           String
  type            MedicalRecordType
  title           String
  description     String            @default("")
  recordedAt      DateTime
  vetName         String?
  nextDueDate     DateTime?
  metadata        Json?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  pet             Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdBy       User              @relation("MedicalRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  attachments     RecordAttachment[]
  sourceEvents    Event[]

  @@index([petId, recordedAt(sort: Desc)])
  @@index([createdByUserId])
}

model RecordAttachment {
  id        String        @id
  recordId  String
  storageKey String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime      @default(now())
  record    MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model Event {
  id              String         @id
  petId           String
  sourceRecordId  String?
  type            EventType
  title           String
  description     String         @default("")
  startAt         DateTime
  endAt           DateTime?
  status          EventStatus    @default(PENDIENTE)
  location        String?
  metadata        Json?
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  pet             Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)
  sourceRecord    MedicalRecord? @relation(fields: [sourceRecordId], references: [id], onDelete: SetNull)
  createdBy       User           @relation("EventCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  reminders       EventReminder[]
  notifications   Notification[]

  @@index([petId, startAt])
  @@index([createdByUserId])
}

model EventReminder {
  id            String         @id
  eventId       String
  channel       ReminderChannel
  offsetMinutes Int
  scheduledFor  DateTime
  sentAt        DateTime?
  status        ReminderStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([status, scheduledFor])
}

model Notification {
  id         String               @id
  userId     String
  petId      String?
  eventId    String?
  type       NotificationType
  title      String
  body       String
  priority   NotificationPriority @default(MEDIUM)
  readAt     DateTime?
  resolvedAt DateTime?
  actionUrl  String?
  createdAt  DateTime             @default(now())
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet        Pet?                 @relation(fields: [petId], references: [id], onDelete: SetNull)
  event      Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([petId])
  @@index([eventId])
}
